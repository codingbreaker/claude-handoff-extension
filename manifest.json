{
  "manifest_version": 3,
  "name": "AI Handoff — by @codingbreaker",
  "version": "2.2",
  "description": "Export any AI conversation → continue on any AI. Accurate token counter with reset times for Claude, ChatGPT, Gemini, Grok, Perplexity & more.",
  "author": "codingbreaker (github.com/codingbreaker)",
  "homepage_url": "https://github.com/codingbreaker",
  "permissions": ["clipboardWrite", "activeTab", "scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.mistral.ai/*",
    "https://poe.com/*",
    "https://you.com/*",
    "https://meta.ai/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["token_bridge.js", "o200k_base.js"],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://poe.com/*",
        "https://you.com/*",
        "https://meta.ai/*",
        "https://*/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://poe.com/*",
        "https://you.com/*",
        "https://meta.ai/*"
      ],
      "js": ["token_counter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://poe.com/*",
        "https://you.com/*",
        "https://meta.ai/*"
      ],
      "js": ["universal_inject.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Handoff by @codingbreaker",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
